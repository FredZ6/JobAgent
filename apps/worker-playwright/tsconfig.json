{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "types": ["node"],
    "typeRoots": ["./src/types", "../../node_modules/@types"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "../../packages/config/src/env.ts",
    "../../packages/config/src/index.ts"
  ]
}
