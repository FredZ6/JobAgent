generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CandidateProfile {
  id                String   @id @default(cuid())
  fullName          String
  email             String
  phone             String
  linkedinUrl       String
  githubUrl         String
  location          String
  workAuthorization String
  summary           String
  skills            Json
  experienceLibrary Json     @default("[]")
  projectLibrary    Json     @default("[]")
  defaultAnswers    Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  resumeVersions    ResumeVersion[]
}

model LlmSetting {
  id           String   @id @default(cuid())
  provider     String
  model        String
  apiKey       String
  isConfigured Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Job {
  id             String          @id @default(cuid())
  sourceUrl      String
  applyUrl       String?
  title          String
  company        String
  location       String
  description    String
  rawText        String
  importStatus   String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  analyses       JobAnalysis[]
  resumeVersions ResumeVersion[]
  applications   Application[]
  events         JobEvent[]
  workflowRuns   WorkflowRun[]
}

model JobAnalysis {
  id               String   @id @default(cuid())
  jobId            String
  matchScore       Int
  summary          String
  requiredSkills   Json
  missingSkills    Json
  redFlags         Json
  structuredResult Json
  status           String
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model ResumeVersion {
  id                  String           @id @default(cuid())
  jobId               String
  sourceProfileId     String
  status              String
  headline            String
  professionalSummary String
  skills              Json
  experienceSections  Json
  projectSections     Json
  changeSummary       Json
  structuredContent   Json
  errorMessage        String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  job                 Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sourceProfile       CandidateProfile @relation(fields: [sourceProfileId], references: [id], onDelete: Cascade)
  applications        Application[]
  workflowRuns        WorkflowRun[]
  automationSessions   AutomationSession[]

  @@index([jobId])
  @@index([sourceProfileId])
}

model Application {
  id              String    @id @default(cuid())
  jobId           String
  resumeVersionId String
  status          String
  approvalStatus  String
  submissionStatus String   @default("not_ready")
  applyUrl        String
  formSnapshot    Json
  fieldResults    Json
  screenshotPaths Json
  workerLog       Json
  submittedAt     DateTime?
  submissionNote  String    @default("")
  submittedByUser Boolean   @default(false)
  finalSubmissionSnapshot Json?
  reviewNote      String
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeVersion   ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  events          ApplicationEvent[]
  workflowRuns    WorkflowRun[]
  automationSessions AutomationSession[]

  @@index([jobId])
  @@index([resumeVersionId])
}

model AutomationSession {
  id              String         @id @default(cuid())
  applicationId   String
  workflowRunId   String?
  resumeVersionId String?
  kind            String
  status          String
  applyUrl        String
  formSnapshot    Json
  fieldResults    Json
  screenshotPaths Json
  workerLog       Json
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  application     Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  workflowRun     WorkflowRun?    @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  resumeVersion   ResumeVersion?  @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)

  @@index([applicationId, createdAt])
  @@index([workflowRunId, createdAt])
  @@index([resumeVersionId, createdAt])
  @@index([status, createdAt])
}

model ApplicationEvent {
  id            String      @id @default(cuid())
  applicationId String
  type          String
  actorType     String      @default("system")
  actorLabel    String      @default("system")
  actorId       String?
  source        String      @default("system")
  payload       Json
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
}

model JobEvent {
  id         String   @id @default(cuid())
  jobId      String
  type       String
  actorType  String   @default("system")
  actorLabel String   @default("system")
  actorId    String?
  source     String   @default("system")
  payload    Json
  createdAt  DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model WorkflowRun {
  id              String        @id @default(cuid())
  jobId           String
  retryOfRunId    String?
  applicationId   String?
  resumeVersionId String?
  kind            String
  status          String
  executionMode   String
  workflowId      String?
  workflowType    String?
  taskQueue       String?
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  job             Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  retryOfRun      WorkflowRun?  @relation("WorkflowRunRetries", fields: [retryOfRunId], references: [id], onDelete: SetNull)
  retries         WorkflowRun[] @relation("WorkflowRunRetries")
  application     Application?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  resumeVersion   ResumeVersion? @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)
  events          WorkflowRunEvent[]
  automationSessions AutomationSession[]

  @@index([jobId, createdAt])
  @@index([retryOfRunId, createdAt])
  @@index([status])
}

model WorkflowRunEvent {
  id            String      @id @default(cuid())
  workflowRunId String
  type          String
  payload       Json
  createdAt     DateTime    @default(now())
  workflowRun   WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId, createdAt])
}
